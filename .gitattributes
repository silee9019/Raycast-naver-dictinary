* text=auto

# Keep Raycast extension source/config/docs reproducible across platforms.
.gitattributes text eol=lf
.editorconfig text eol=lf
.gitignore text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.d.ts text eol=lf
*.lock text eol=lf
*.xml text eol=lf
*.iml text eol=lf
.npmrc text eol=lf
.prettierrc text eol=lf

# Treat Raycast icons and store screenshots as binary assets.
*.png binary
